# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/krushiconnect

# JWT
JWT_SECRET=your_jwt_secret_here

# Cloudinary (required for product images on Render)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server
PORT=5000
NODE_ENV=production
